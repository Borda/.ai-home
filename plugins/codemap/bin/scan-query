#!/usr/bin/env python3
"""scan-query — query the codemap structural index.

Commands:
  deps <module>           What does this module import?
  rdeps <module>          What imports this module?
  central [--top N]       Most-imported modules (highest blast radius)
  coupled [--top N]       Modules with the most imports (highest coupling)
  path <from> <to>        Shortest import path between two modules
  symbol <name>           Get source of a symbol by name (function/class/method)
  symbols <module>        List all symbols in a module
  find-symbol <pattern>   Regex search across all symbol names

All output is JSON. Staleness is checked on every invocation — warns to
stderr if Python files were committed after the index was built.

Usage:
    scan-query central --top 5
    scan-query coupled --top 5
    scan-query deps mypackage.auth
    scan-query rdeps mypackage.models
    scan-query path mypackage.api mypackage.db
    scan-query symbol authenticate
    scan-query symbols mypackage.auth
    scan-query find-symbol '^Auth.*Handler$'
"""

from __future__ import annotations

import argparse
import json
import re
import subprocess
import sys
from collections import deque
from pathlib import Path
from typing import TypedDict


class Symbol(TypedDict):
    name: str
    qualified_name: str
    type: str  # "class" | "function" | "method"
    start_line: int
    end_line: int


# ---------------------------------------------------------------------------
# Index location
# ---------------------------------------------------------------------------


def _git_root() -> Path | None:
    try:
        root = subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], text=True, stderr=subprocess.DEVNULL
        ).strip()
        return Path(root)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def find_index() -> Path:
    """Locate the codemap index using a multi-strategy search.

    1. Git root — <git-root>/.cache/scan/<name>.json (standard case)
    2. Walk up from CWD — finds index in ZIP exports and non-git repos
    3. Fallback — CWD convention; produces a clear error if missing
    """
    # Strategy 1: git root owns the index
    git_root = _git_root()
    if git_root:
        candidate = git_root / ".cache" / "scan" / f"{git_root.name}.json"
        if candidate.exists():
            return candidate

    # Strategy 2: walk up from CWD — handles ZIP archives without .git
    for parent in [Path.cwd(), *Path.cwd().parents]:
        scan_dir = parent / ".cache" / "scan"
        if scan_dir.is_dir():
            preferred = scan_dir / f"{parent.name}.json"
            if preferred.exists():
                return preferred
            candidates = sorted(scan_dir.glob("*.json"))
            if candidates:
                return candidates[0]

    # Strategy 3: fallback (will surface a clear "Index not found" error)
    root = git_root or Path.cwd()
    return root / ".cache" / "scan" / f"{root.name}.json"


def load_index(path: Path) -> dict:
    if not path.exists():
        _exit_error(f"Index not found at {path}. Run /codemap:scan first.")
    with path.open() as f:
        return json.load(f)


# ---------------------------------------------------------------------------
# Staleness check
# ---------------------------------------------------------------------------


def check_staleness(scanned_at: str) -> bool:
    """Return True if any Python code file changed after scanned_at."""
    try:
        result = subprocess.run(
            [
                "git",
                "log",
                f"--since={scanned_at}",
                "--name-only",
                "--pretty=",
                "--",
                "*.py",
                ":!docs/",
                ":!*.md",
                ":!*.rst",
                ":!.github/",
                ":!**/*.yml",
                ":!**/*.yaml",
            ],
            capture_output=True,
            text=True,
        )
        if result.returncode != 0:
            return False
        return bool(result.stdout.strip())
    except Exception:
        return False


def warn_if_stale(index: dict) -> None:
    scanned_at = index.get("scanned_at", "")
    if scanned_at and check_staleness(scanned_at):
        print(
            "⚠ codemap index may be stale — Python files changed since last scan. Re-run /codemap:scan.",
            file=sys.stderr,
        )


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def build_module_map(index: dict) -> dict[str, dict]:
    return {m["name"]: m for m in index.get("modules", [])}


def _exit_error(message: str) -> None:
    print(json.dumps({"error": message}))
    sys.exit(1)


def _current_git_sha() -> str | None:
    """Return current HEAD SHA, or None if git is unavailable."""
    try:
        return subprocess.check_output(["git", "rev-parse", "HEAD"], text=True, stderr=subprocess.DEVNULL).strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def _coverage(index: dict) -> dict:
    """Return an index coverage block for every query result.

    Embeds a machine-readable completeness guarantee and a staleness signal
    so agents know whether the index matches the current codebase state.
    When git is present, compares the SHA recorded at scan time against HEAD.
    """
    modules = index.get("modules", [])
    total = sum(1 for m in modules if m.get("status") == "ok")
    degraded = sum(1 for m in modules if m.get("status") == "degraded")

    scan_sha: str | None = index.get("git_sha")
    current_sha = _current_git_sha()

    if scan_sha and current_sha:
        stale = scan_sha != current_sha
        sha_info = {"scan_sha": scan_sha[:12], "current_sha": current_sha[:12]}
    else:
        stale = False  # can't determine without git
        sha_info = {}

    if stale:
        note = (
            f"All {total} indexed modules were searched. "
            f"⚠ Index may be stale — built at {scan_sha[:12]}, "
            f"HEAD is now {current_sha[:12]}. "  # type: ignore[index]
            "Re-run /codemap:scan to update before relying on this result."
        )
    else:
        note = (
            f"All {total} indexed modules were searched. "
            "This result is complete — grep/bash verification is not needed."
        )

    return {
        "total_modules": total,
        "degraded": degraded,
        "exhaustive": not stale,
        "stale": stale,
        **sha_info,
        "note": note,
    }


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------


def cmd_deps(index: dict, module: str) -> None:
    modules = build_module_map(index)
    entry = modules.get(module)
    if entry is None:
        _exit_error(f"Module '{module}' not in index.")
    print(
        json.dumps(
            {
                "module": module,
                "direct_imports": entry.get("direct_imports", []),
                "index": _coverage(index),
            }
        )
    )


def cmd_rdeps(index: dict, module: str) -> None:
    result = sorted(m["name"] for m in index.get("modules", []) if module in m.get("direct_imports", []))
    print(json.dumps({"module": module, "imported_by": result, "index": _coverage(index)}))


def cmd_central(index: dict, top: int) -> None:
    candidates = [m for m in index.get("modules", []) if m.get("status") != "degraded"]
    ranked = sorted(candidates, key=lambda m: m.get("rdep_count", 0), reverse=True)[:top]
    print(
        json.dumps(
            {
                "central": [
                    {"name": m["name"], "rdep_count": m.get("rdep_count", 0), "path": m.get("path", "")} for m in ranked
                ],
                "index": _coverage(index),
            }
        )
    )


def cmd_coupled(index: dict, top: int) -> None:
    candidates = [m for m in index.get("modules", []) if m.get("status") != "degraded"]
    ranked = sorted(candidates, key=lambda m: m.get("dep_count", 0), reverse=True)[:top]
    print(
        json.dumps(
            {
                "coupled": [
                    {"name": m["name"], "dep_count": m.get("dep_count", 0), "path": m.get("path", "")} for m in ranked
                ],
                "index": _coverage(index),
            }
        )
    )


def cmd_path(index: dict, frm: str, to: str) -> None:
    modules = build_module_map(index)
    if frm not in modules:
        _exit_error(f"Module '{frm}' not in index.")
    if to not in modules:
        _exit_error(f"Module '{to}' not in index.")

    queue: deque[list[str]] = deque([[frm]])
    visited: set[str] = {frm}
    while queue:
        path = queue.popleft()
        node = path[-1]
        if node == to:
            print(json.dumps({"from": frm, "to": to, "path": path, "index": _coverage(index)}))
            return
        for neighbour in modules.get(node, {}).get("direct_imports", []):
            if neighbour not in visited and neighbour in modules:
                visited.add(neighbour)
                queue.append(path + [neighbour])

    print(
        json.dumps({"from": frm, "to": to, "path": None, "error": "No import path found.", "index": _coverage(index)})
    )


def cmd_list(index: dict) -> None:
    modules = [
        {"name": m["name"], "path": m.get("path", ""), "status": m.get("status", "ok")}
        for m in index.get("modules", [])
    ]
    print(json.dumps({"modules": modules}))


def _read_lines(index: dict, module_entry: dict, start_line: int, end_line: int) -> str:
    """Read lines start_line..end_line (1-based, inclusive) from the module's source file."""
    git_root = _git_root()
    if git_root is None:
        git_root = Path.cwd()
    file_path = git_root / module_entry["path"]
    if not file_path.exists():
        return ""
    lines = file_path.read_text(encoding="utf-8", errors="replace").splitlines()
    return "\n".join(lines[start_line - 1 : end_line])


def cmd_symbol(index: dict, name: str) -> None:
    """Find a symbol by name (exact match, then qualified_name substring) and return its source."""
    matches: list[tuple[dict, Symbol]] = []
    for m in index.get("modules", []):
        if m.get("status") == "degraded":
            continue
        for sym in m.get("symbols", []):
            if sym["name"] == name or sym["qualified_name"] == name:
                matches.append((m, sym))

    if not matches:
        # Fallback: case-insensitive substring on qualified_name
        name_lower = name.lower()
        for m in index.get("modules", []):
            if m.get("status") == "degraded":
                continue
            for sym in m.get("symbols", []):
                if name_lower in sym["qualified_name"].lower():
                    matches.append((m, sym))

    if not matches:
        _exit_error(f"Symbol '{name}' not found. Try /codemap:query find-symbol <pattern> to search.")

    results = []
    for m, sym in matches:
        source = _read_lines(index, m, sym["start_line"], sym["end_line"])
        results.append(
            {
                "name": sym["name"],
                "qualified_name": sym["qualified_name"],
                "type": sym["type"],
                "module": m["name"],
                "path": m.get("path", ""),
                "start_line": sym["start_line"],
                "end_line": sym["end_line"],
                "source": source,
            }
        )
    print(json.dumps({"symbols": results, "count": len(results), "index": _coverage(index)}))


def cmd_symbols(index: dict, module: str) -> None:
    """List all symbols in a module (no file I/O — index only)."""
    modules = build_module_map(index)
    entry = modules.get(module)
    if entry is None:
        _exit_error(f"Module '{module}' not in index.")
    syms: list[Symbol] = entry.get("symbols", [])
    print(
        json.dumps(
            {
                "module": module,
                "path": entry.get("path", ""),
                "symbols": [
                    {
                        "name": s["name"],
                        "qualified_name": s["qualified_name"],
                        "type": s["type"],
                        "start_line": s["start_line"],
                        "end_line": s["end_line"],
                    }
                    for s in syms
                ],
                "count": len(syms),
                "index": _coverage(index),
            }
        )
    )


def cmd_find_symbol(index: dict, pattern: str) -> None:
    """Regex search across all symbol qualified_names in the index."""
    try:
        rx = re.compile(pattern, re.IGNORECASE)
    except re.error as exc:
        _exit_error(f"Invalid regex '{pattern}': {exc}")

    results = []
    for m in index.get("modules", []):
        if m.get("status") == "degraded":
            continue
        for sym in m.get("symbols", []):
            if rx.search(sym["qualified_name"]):
                results.append(
                    {
                        "name": sym["name"],
                        "qualified_name": sym["qualified_name"],
                        "type": sym["type"],
                        "module": m["name"],
                        "path": m.get("path", ""),
                        "start_line": sym["start_line"],
                        "end_line": sym["end_line"],
                    }
                )
    print(json.dumps({"pattern": pattern, "matches": results, "count": len(results), "index": _coverage(index)}))


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Query the codemap structural index.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    p_deps = sub.add_parser("deps", help="What does a module import?")
    p_deps.add_argument("module")

    p_rdeps = sub.add_parser("rdeps", help="What imports a module?")
    p_rdeps.add_argument("module")

    p_central = sub.add_parser("central", help="Most-imported modules (highest blast radius).")
    p_central.add_argument("--top", type=int, default=10, metavar="N")

    p_coupled = sub.add_parser("coupled", help="Modules with the most imports (highest coupling).")
    p_coupled.add_argument("--top", type=int, default=10, metavar="N")

    p_path = sub.add_parser("path", help="Shortest import path between two modules.")
    p_path.add_argument("frm", metavar="from")
    p_path.add_argument("to")

    sub.add_parser("list", help="List all indexed modules.")

    p_symbol = sub.add_parser("symbol", help="Get source of a symbol by name (function/class/method).")
    p_symbol.add_argument("name", help="Symbol name, e.g. 'authenticate' or 'MyClass.method'")

    p_symbols = sub.add_parser("symbols", help="List all symbols in a module.")
    p_symbols.add_argument("module", help="Dotted module name, e.g. 'mypackage.auth'")

    p_find = sub.add_parser("find-symbol", help="Regex search across all symbol names.")
    p_find.add_argument("pattern", help="Python regex pattern, e.g. 'auth' or '^My.*Handler$'")

    parser.add_argument("--index", metavar="PATH", help="Explicit path to the index JSON (auto-discovered if omitted).")

    args = parser.parse_args()

    index_path = Path(args.index) if args.index else find_index()
    index = load_index(index_path)
    warn_if_stale(index)

    if args.command == "deps":
        cmd_deps(index, args.module)
    elif args.command == "rdeps":
        cmd_rdeps(index, args.module)
    elif args.command == "central":
        cmd_central(index, args.top)
    elif args.command == "coupled":
        cmd_coupled(index, args.top)
    elif args.command == "path":
        cmd_path(index, args.frm, args.to)
    elif args.command == "list":
        cmd_list(index)
    elif args.command == "symbol":
        cmd_symbol(index, args.name)
    elif args.command == "symbols":
        cmd_symbols(index, args.module)
    elif args.command == "find-symbol":
        cmd_find_symbol(index, args.pattern)


if __name__ == "__main__":
    main()
